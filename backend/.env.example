# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/moment?schema=public&connection_limit=1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Logging
ENABLE_TEMP_TIMING_LOGS=1 # Set to 1 to enable temporary timing logs for debugging purposes. Remember to set it back to 0 when done.

# Workers

# If there are no scheduled/active moments, check every 5 minutes
MOMENT_WORKER_IDLE_INTERVAL_MS=300000

# if there are scheduled/active moments, check every 30 seconds 
MOMENT_WORKER_ACTIVE_INTERVAL_MS=30000

# Start processing moments after an initial delay of 5 seconds (to allow the server to start up properly) 
MOMENT_WORKER_INITIAL_DELAY_MS=5000
