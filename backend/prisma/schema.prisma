generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ConversationType {
  friend
  group_pair
  group
}

enum MomentMatchType {
  friend
  group
}

enum MomentMatchStatus {
  scheduled
  active
  successful
  expired
}

enum MomentOptInState {
  pending
  opted_in
}

model users {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String   @unique
  avatar_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  friendships_as_requester  friendships[]               @relation("FriendshipRequester")
  friendships_as_addressee  friendships[]               @relation("FriendshipAddressee")
  group_memberships         group_members[]
  messages                  messages[]
  user_answers              user_answers[]
  games                     games[]
  conversation_participants conversation_participants[]
  moment_matches_as_user_a  moment_matches[]            @relation("MomentMatchUserA")
  moment_matches_as_user_b  moment_matches[]            @relation("MomentMatchUserB")
}

model friendships {
  id           String   @id @default(uuid())
  requester_id String
  addressee_id String
  status       String   @default("pending") // pending, accepted, rejected
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  requester users @relation("FriendshipRequester", fields: [requester_id], references: [id])
  addressee users @relation("FriendshipAddressee", fields: [addressee_id], references: [id])

  @@unique([requester_id, addressee_id])
  @@index([requester_id, status])
  @@index([addressee_id, status])
}

model groups {
  id              String    @id @default(uuid())
  name            String
  invite_code     String    @unique
  created_by      String
  conversation_id String?   @unique
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  members           group_members[]
  chat_conversation conversations?  @relation("GroupChatConversation", fields: [conversation_id], references: [id])
  moment_matches    moment_matches[]
}

model group_members {
  id        String   @id @default(uuid())
  user_id   String
  group_id  String
  joined_at DateTime @default(now())

  user  users  @relation(fields: [user_id], references: [id])
  group groups @relation(fields: [group_id], references: [id])

  @@unique([user_id, group_id])
  @@index([group_id])
  @@index([user_id])
}

model messages {
  id              String   @id @default(uuid())
  conversation_id String
  sender_id       String
  content         String
  created_at      DateTime @default(now())
  deleted_at      DateTime?

  conversation conversations @relation(fields: [conversation_id], references: [id])
  sender       users         @relation(fields: [sender_id], references: [id])

  @@index([conversation_id, deleted_at, created_at])
  @@index([sender_id])
}

model daily_questions {
  id            String   @id @default(uuid())
  question_text String
  question_date DateTime @unique
  created_at    DateTime @default(now())

  user_answers user_answers[]
}

model user_answers {
  id          String   @id @default(uuid())
  user_id     String
  question_id String
  answer_text String
  created_at  DateTime @default(now())

  user     users           @relation(fields: [user_id], references: [id])
  question daily_questions @relation(fields: [question_id], references: [id])

  @@unique([question_id, user_id])
}

model games {
  id          String   @id @default(uuid())
  user_id     String
  game_type   String // this-or-that, would-you-rather, personality-quiz
  result_data Json
  created_at  DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}

model conversations {
  id         String           @id @default(uuid())
  type       ConversationType
  title      String?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  deleted_at DateTime?

  participants conversation_participants[]
  messages     messages[]
  group        groups?                     @relation("GroupChatConversation")
  moment_matches moment_matches[]

  @@index([deleted_at, type, updated_at])
}

model conversation_participants {
  id              String   @id @default(uuid())
  conversation_id String
  user_id         String
  is_muted        Boolean  @default(false)
  joined_at       DateTime @default(now())

  conversation conversations @relation(fields: [conversation_id], references: [id])
  user         users         @relation(fields: [user_id], references: [id])

  @@unique([conversation_id, user_id])
  @@index([user_id, conversation_id])
}

model moment_matches {
  id                 String            @id @default(uuid())
  match_type         MomentMatchType
  status             MomentMatchStatus @default(scheduled)
  user_a_id          String
  user_b_id          String
  group_id           String?
  conversation_id    String
  scheduled_day      DateTime
  scheduled_at       DateTime
  expires_at         DateTime
  reminder_sent_at   DateTime?
  user_a_opt_in      MomentOptInState  @default(pending)
  user_b_opt_in      MomentOptInState  @default(pending)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  user_a       users         @relation("MomentMatchUserA", fields: [user_a_id], references: [id])
  user_b       users         @relation("MomentMatchUserB", fields: [user_b_id], references: [id])
  group        groups?       @relation(fields: [group_id], references: [id])
  conversation conversations @relation(fields: [conversation_id], references: [id])

  @@unique([scheduled_day, match_type, user_a_id])
  @@unique([scheduled_day, match_type, user_b_id])
  @@unique([scheduled_day, match_type, user_a_id, user_b_id])
  @@index([status, expires_at])
  @@index([user_a_id, match_type, scheduled_at])
  @@index([user_b_id, match_type, scheduled_at])
  @@index([conversation_id])
  @@index([group_id])
}
